#!/usr/bin/env bash
# symlink - Create symlinks in /usr/local/bin for executables
# Features: .symlink batch files, auto-sudo, critical file protection, dry-run
# License: GPL-3.0
set -euo pipefail
shopt -s inherit_errexit shift_verbose extglob nullglob
declare -rx PATH=/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/usr/sbin:/sbin
# Enforce root privileges at the very beginning
((EUID==0)) || {
  sudo -ln &>/dev/null || {
    >&2 echo "$(basename "$0"): error: Requires root," \
      "or non-interactive sudo privileges."
    exit 1
  }
  # Forward only the safe debug var across the privilege boundary; do NOT use
  # `sudo -E` — that would carry SYMLINK_FORCE_CRITICAL (critical-file override)
  # into the root re-exec without re-validation. Real root may still set it.
  sudo SYMLINK_DEBUG="${SYMLINK_DEBUG:-}" "$0" "$@"
  exit "$?"
}

declare -r VERSION=1.5.0
declare -- SCRIPT_PATH
SCRIPT_PATH=$(realpath -- "$0")
readonly SCRIPT_PATH
declare -r SCRIPT_NAME=${SCRIPT_PATH##*/}

declare -- ORIG_DIR
ORIG_DIR=$(pwd 2>/dev/null) || ORIG_DIR=''
readonly ORIG_DIR
declare -r DEFAULT_TARGET_DIR=${DEFAULT_TARGET_DIR:-/usr/local/bin}
# Hard-protected names: replacing one requires interactive confirmation or
# SYMLINK_FORCE_CRITICAL. This is a best-effort UX guard, NOT a security
# boundary (the real boundary is "don't scan untrusted trees as root", enforced
# by the .symlink source/link-name containment checks). Any OTHER name that
# would shadow a real PATH command is handled dynamically — see shadowed_command.
declare -ra CRITICAL_FILES=(
  apt awk bash cat chgrp chmod chown clang cp crontab dash date dd df du
  dpkg echo env file find gcc git grep groupadd groupdel head hostname
  ifconfig ip kill less ln login ls make mkdir mount mv netstat passwd
  ping ps reboot rm rmdir scp sed sh shutdown ss ssh su sudo systemctl
  tail top touch umount useradd userdel vi vim visudo zsh
)

# Initialize key variables early
declare -i SCANSYMLINK=0
declare -i DELETE_DEAD_SYMLINKS=0
declare -i LISTIT=0
declare -i FORCE=0      # -f: clobber pre-existing non-symlink files non-interactively
declare -i BACKUP=0     # --backup: rename a clobbered file to name.bak~ first
declare -i FIND_MAX_DEPTH=5
declare -a CREATED_LINKS=()
declare -a REPLACED_LINKS=()
declare -a SKIPPED_LINKS=()
declare -a ERROR_LINKS=()

# --------------------------------------------------------------------------------
# Message functions and color support
# --------------------------------------------------------------------------------
declare -i DRY_RUN=0 VERBOSE=0 DEBUG=0 PROMPT=0
# Set PROMPT based on whether we're running interactively
# If stdin is not a terminal, disable prompting by default
# PROMPT=0  Non-interactive - no prompting by default
[[ -t 0 ]] && PROMPT=1 || :  # Interactive - prompting enabled by default

if [[ -t 2 ]]; then
  declare -r RED=$'\033[0;31m' GREEN=$'\033[0;32m' \
    YELLOW=$'\033[0;33m' CYAN=$'\033[0;36m' NC=$'\033[0m'
else
  declare -r RED='' GREEN='' YELLOW='' CYAN='' NC=''
fi

# _msg MESSAGES... - Formats output with caller-specific color/icon prefix
_msg() {
  local -- prefix="$SCRIPT_NAME:" msg
  case ${FUNCNAME[1]} in
    success) prefix+=" ${GREEN}✓${NC}" ;;
    warn)    prefix+=" ${YELLOW}▲${NC}" ;;
    info)    prefix+=" ${CYAN}◉${NC}" ;;
    error)   prefix+=" ${RED}✗${NC}" ;;
    debug)   prefix+=" ${RED}DEBUG${NC}:" ;;
    *)       ;;
  esac
  for msg in "$@"; do printf '%s %s\n' "$prefix" "$msg"; done
}

# Verbose output (stderr)
success() { ((VERBOSE)) || return 0; >&2 _msg "$@"; }
# warn() is unconditional: safety-relevant warnings (critical-file, target-dir
# scan, failed cleanup) must surface even in the default non-verbose -SPd run.
warn() { >&2 _msg "$@"; }
info() { ((VERBOSE)) || return 0; >&2 _msg "$@"; }
# Debug output (stderr, requires DEBUG=1)
debug() { ((DEBUG)) || return 0; >&2 _msg "$@"; }
# Unconditional output (stderr)
error() { >&2 _msg "$@"; }
# die EXIT_CODE [MESSAGES...] - Print error message(s) to stderr, then exit
die() { (($# < 2)) || error "${@:2}"; exit "${1:-0}"; }
# yes/no prompt
yn() {
  ((PROMPT)) || return 0
  local -- REPLY
  read -r -n 1 -p "$SCRIPT_NAME: ${YELLOW}▲${NC} ${1:-'Continue?'} y/n " </dev/tty
  echo
  [[ ${REPLY,,} == y ]]
}

# --------------------------------------------------------------------------------
# Utility functions
# --------------------------------------------------------------------------------
# Validate argument presence
noarg() { (($# > 1)) || die 22 "Option ${1@Q} requires an argument"; }

# cleanup - EXIT trap handler for finalization and debug logging
cleanup() {
  cd "$ORIG_DIR" 2>/dev/null || true
  if ((DEBUG)); then
    { echo "TRACE: Created links: ${#CREATED_LINKS[@]}"
      echo "TRACE: Replaced links: ${#REPLACED_LINKS[@]}"
      echo "TRACE: Skipped links: ${#SKIPPED_LINKS[@]}"
      echo "TRACE: Error links: ${#ERROR_LINKS[@]}"
      echo "TRACE: Execution completed at $(date -Is)"
      echo "TRACE: =============== END OF EXECUTION ==============="
    } >> "$TRACEFILE"
    debug "Debug log written to ${TRACEFILE@Q}"
  fi
}

# --------------------------------------------------------------------------------
# Pre-Check DEBUG flag
# --------------------------------------------------------------------------------
# Enable debug mode if requested through environment variable or command line flag
[[ -z "${SYMLINK_DEBUG:-}" ]] || DEBUG=1
if (($#)); then
  for arg in "$@"; do [[ "$arg" == '--debug' ]] && { DEBUG=1; break; } ||:; done
fi
# Setup debug trace if in debug mode
declare -- TRACEFILE=/dev/null
if ((DEBUG)); then
  # mktemp creates the file with O_EXCL and mode 0600 — defeats a predictable
  # /tmp symlink-attack vector when running as root. TMPDIR lets tests isolate
  # traces into a private dir. Fall back to /dev/null on failure.
  TRACEFILE=$(mktemp "${TMPDIR:-/tmp}/symlink-trace-$(whoami)-XXXXXX.log") || TRACEFILE=/dev/null
  { echo "TRACE: Script started at $(date -Is)"
    echo "TRACE: Arguments: $*"
    echo "TRACE: Working dir: $(pwd)"
    echo "TRACE: Running as: $(whoami), EUID: $EUID"
  } > "$TRACEFILE"
  debug "Debug mode enabled (logging to $TRACEFILE)"
fi
trap cleanup EXIT
# Root privileges enforced at script start (lines 9-17)
debug "Running as root user: EUID=$EUID"

show_help() {
  cat <<HELP
