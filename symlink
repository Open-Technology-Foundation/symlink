}

# --------------------------------------------------------------------------------
# String manipulation functions
# --------------------------------------------------------------------------------
# trim STRING - Remove leading/trailing blanks (spaces and tabs); outputs to stdout
trim() {
  local -- v="$*"
  v="${v#"${v%%[![:blank:]]*}"}"
  # printf (not echo -n) so a value of exactly -n/-e/-E is not eaten as a flag.
  printf '%s' "${v%"${v##*[![:blank:]]}"}"
}

# --------------------------------------------------------------------------------
# File validation functions
# --------------------------------------------------------------------------------
# is_critical_file FILENAME - Returns 0 if in CRITICAL_FILES array, 1 otherwise
is_critical_file() {
  # Compare on basename only so a path-qualified name cannot dodge the check.
  local -- filename="${1##*/}" critical
  for critical in "${CRITICAL_FILES[@]}"; do
    [[ "$filename" == "$critical" ]] && return 0 ||:
  done
  return 1
}

# shadowed_command NAME TARGET_DIR
# If NAME resolves to an executable on PATH OUTSIDE target_dir, echo that path
# (the command the new link would shadow) and return 0; otherwise return 1.
# Walks PATH directly (PATH is readonly, so it cannot be reassigned) and skips
# target_dir so an existing link there is not mistaken for the shadowed command.
shadowed_command() {
  local -- name="${1##*/}" target_dir="$2" dir
  local -a parts=()
  IFS=: read -ra parts <<< "$PATH"
  for dir in "${parts[@]}"; do
    [[ -z "$dir" || "$dir" == "$target_dir" ]] && continue
    if [[ -f "$dir/$name" && -x "$dir/$name" ]]; then
      printf '%s' "$dir/$name"
      return 0
    fi
  done
  return 1
}

# --------------------------------------------------------------------------------
# Core symlink operations
# --------------------------------------------------------------------------------
# create_symlink SOURCE TARGET_DIR [CUSTOM_NAME]
# Creates symlink in TARGET_DIR pointing to SOURCE. Returns: 0=ok, 1=error, 2=perm, 3=notfound
# Updates global arrays: CREATED_LINKS, REPLACED_LINKS, SKIPPED_LINKS, ERROR_LINKS
create_symlink() {
  local -- source_path=$1
  local -- target_dir=$2
  local -- custom_target_name=${3:-}
  local -- target_name target_path
  local -i exit_code=0
  local -i was_replaced=0  # replacing an existing link/file must not also count as created

  # Get target filename - use custom name if provided, otherwise use basename
  # ${var##*/} not basename: a source whose name starts with '-' would make
  # basename treat it as an option, failing the command-sub and aborting set -e.
  target_name="${custom_target_name:-${source_path##*/}}"
  target_path="${target_dir}/${target_name}"
  debug "create_symlink: $source_path → $target_path"

  # Check if the source file exists and is executable
  if [[ ! -f "$source_path" ]]; then
    error "Source file does not exist ${source_path@Q}"
    ERROR_LINKS+=("$source_path → $target_path (source not found)")
    if ((DRY_RUN)); then
      info "[DRY RUN] Would fail: Source file does not exist ${source_path@Q}"
      return 0
    fi
    return 3
  fi

  if [[ ! -x "$source_path" ]]; then
    error "Source file is not executable ${source_path@Q}"
    ERROR_LINKS+=("$source_path → $target_path (not executable)")
    if ((DRY_RUN)); then
      info "[DRY RUN] Would fail: Source file not executable ${source_path@Q}"
      return 0
    fi
    return 1
  fi

  # Get absolute path to source with timeout to prevent hanging
  local -- source_abs_path
  source_abs_path=$(timeout 2 realpath -- "$source_path" 2>/dev/null) || source_abs_path=''

  if [[ -z "$source_abs_path" ]]; then
    error "Failed to resolve source path: '$source_path'"
    ERROR_LINKS+=("$source_path → $target_path (path resolution failed)")
    return 1
  fi

  # Check if target directory exists and is writable
  if [[ ! -d "$target_dir" ]]; then
    error "Target directory does not exist: '$target_dir'"
    ERROR_LINKS+=("$source_path → $target_path (target dir not found)")
    if ((DRY_RUN)); then
      info "[DRY RUN] Would fail: Target directory does not exist ${target_dir@Q}"
      return 0
    fi
    return 3
  fi

  if [[ ! -w "$target_dir" ]]; then
    error "No write permission on target directory ${target_dir@Q}"
    ERROR_LINKS+=("$source_path → $target_path (permission denied)")
    if ((DRY_RUN)); then
      info "[DRY RUN] Would fail: No write permission on target directory ${target_dir@Q}"
      return 0
    fi
    return 2
  fi

  # Check for critical system files
  if is_critical_file "$target_name"; then
    warn "${target_name@Q} appears to be a critical system file!"

    # In non-interactive or dry-run mode, handle specially
    if ((DRY_RUN)); then
      info "[DRY RUN] Would prompt user for confirmation before replacing critical file"
      SKIPPED_LINKS+=("$source_path → $target_path (critical file)")
      return 0
    fi

    if ((PROMPT)); then
      # Interactive: prompt user
      if ! yn "Are you ABSOLUTELY SURE you want to replace ${target_name@Q}?"; then
        info "Skipping ${target_name@Q} (critical system file)"
        SKIPPED_LINKS+=("$source_path → $target_path (critical file)")
        return 0
      fi
      warn "User explicitly confirmed replacing critical system file"
    elif [[ -n "${SYMLINK_FORCE_CRITICAL:-}" ]]; then
      # Non-interactive with explicit override
      warn "CRITICAL FILE REPLACED: ${target_name@Q}" \
        "(non-interactive mode with SYMLINK_FORCE_CRITICAL)"
    else
      # Non-interactive without override: skip for safety
      info "Skipping ${target_name@Q} (critical system file in non-interactive mode)"
      SKIPPED_LINKS+=("$source_path → $target_path (critical file)")
      return 0
    fi
  else
    # PATH-shadow advisory (only when NOT a hard-protected critical file):
    # if this link would override a real command elsewhere on PATH, surface it.
    # Non-blocking by default — overriding via /usr/local/bin is normal usage —
    # but prompt in interactive mode so the user can back out.
    local -- shadowed
    shadowed=$(shadowed_command "$target_name" "$target_dir") || shadowed=''
    if [[ -n "$shadowed" ]]; then
      warn "${target_name@Q} will shadow ${shadowed@Q} on PATH"
      if ((PROMPT && DRY_RUN == 0)) && ! yn "Create ${target_name@Q}, shadowing ${shadowed@Q}?"; then
        info "Skipping ${target_name@Q}"
        SKIPPED_LINKS+=("$source_path → $target_path (user skipped shadow)")
        return 0
      fi
    fi
  fi

  # Dry run mode
  if ((DRY_RUN)); then
    if [[ -L "$target_path" ]]; then
      # Check if it's already pointing to our target
      local -- current_target
      # errexit-safe: a broken/circular target makes realpath non-zero; without
      # the guard, set -e + inherit_errexit would abort the whole run here.
      current_target=$(realpath -- "$target_path" 2>/dev/null) || current_target=''
      if [[ "$current_target" == "$source_abs_path" ]]; then
        info "[DRY RUN] Would skip (already linked): '$source_abs_path' → '$target_path'"
        SKIPPED_LINKS+=("$source_path → $target_path (already exists)")
      else
        info "[DRY RUN] Would replace symlink: '$source_abs_path' → '$target_path'"
        REPLACED_LINKS+=("$source_path → $target_path (replaced symlink)")
      fi
    elif [[ -e "$target_path" ]]; then
      if ((PROMPT || FORCE)); then
        info "[DRY RUN] Would replace file: '$source_abs_path' → '$target_path'"
        REPLACED_LINKS+=("$source_path → $target_path (replaced file)")
      else
        info "[DRY RUN] Would skip (existing non-symlink, use --force): '$target_path'"
        SKIPPED_LINKS+=("$source_path → $target_path (existing non-symlink, use --force)")
      fi
    else
      info "[DRY RUN] Would create symlink: '$source_abs_path' → '$target_path'"
      CREATED_LINKS+=("$source_path → $target_path")
    fi
    return 0
  fi

  # Handle existing symlink
  if [[ -L "$target_path" ]]; then
    local -- current_target
    # errexit-safe: a broken/circular target makes realpath non-zero; without
    # the guard, set -e + inherit_errexit would abort the whole run here.
    current_target=$(realpath -- "$target_path" 2>/dev/null) || current_target=''

    # Already pointing to our target — nothing to do
    if [[ "$current_target" == "$source_abs_path" ]]; then
      info "Symlink already points to ${source_abs_path@Q}, skipping"
      change_symlink_owner_perms "$source_abs_path" "$target_path"
      SKIPPED_LINKS+=("$source_path → $target_path (already exists)")
      return 0
    fi

    # Broken symlink — replace silently (no value in keeping it)
    if [[ -z "$current_target" ]]; then
      info "Replacing broken symlink ${target_name@Q}"
    elif ((PROMPT)); then
      # Live symlink pointing elsewhere — prompt user
      if ! yn "Replace existing symlink ${target_name@Q} → ${current_target@Q}?"; then
        info "Skipping ${target_name@Q}"
        SKIPPED_LINKS+=("$source_path → $target_path (user skipped)")
        return 0
      fi
    else
      info "Removing existing symlink ${target_path@Q}"
    fi

    # The existing symlink is replaced atomically by the final mv -fT below —
    # no explicit rm here, so there is never a window where neither link exists.
    REPLACED_LINKS+=("$source_path → $target_path (replaced symlink)")
    was_replaced=1
  fi

  # Handle existing regular file (NOT a symlink — likely admin-installed, not
  # created by this tool). Destroying it is real data loss, so the default in
  # non-interactive mode is to SKIP unless -f/--force is given.
  # NOTE: ! -L — an existing *symlink* was already handled above; since we no
  # longer rm it there (atomic replace below), exclude it here so a live symlink
  # is not misclassified as a regular file and wrongly skipped.
  if [[ -e "$target_path" && ! -L "$target_path" ]]; then
    info "File exists ${target_path@Q}"
    if ((PROMPT)); then
      if ! yn "Remove existing file ${target_name@Q}?"; then
        info "Skipping ${target_name@Q}"
        SKIPPED_LINKS+=("$source_path → $target_path (user skipped)")
        return 0
      fi
    elif ((FORCE)); then
      info "Removing existing file ${target_path@Q} (--force)"
    else
      warn "Skipping ${target_name@Q}: target is an existing non-symlink file" \
        "(use --force to replace)"
      SKIPPED_LINKS+=("$source_path → $target_path (existing non-symlink, use --force)")
      return 0
    fi

    # Back up before clobbering when requested. Without --backup the existing
    # file is replaced atomically by the final mv -fT below (it is never removed
    # before the new link exists), so no explicit rm is needed here.
    if ((BACKUP)); then
      if mv -f -- "$target_path" "${target_path}.bak~"; then
        info "Backed up existing file to ${target_path@Q}.bak~"
      else
        error "Failed to back up existing file ${target_path@Q}"
        ERROR_LINKS+=("$source_path → $target_path (backup failed)")
        return 1
      fi
    fi
    REPLACED_LINKS+=("$source_path → $target_path (replaced file)")
    was_replaced=1
  fi

  # Create the symbolic link atomically: build it under a temp name in the SAME
  # directory, then mv -fT it over the target. rename(2) is atomic and never
  # destroys an existing target before the replacement exists, so a failed ln
  # (ENOSPC, race, read-only dir) can no longer leave neither file nor link.
  info "Creating symlink: '$source_abs_path' → '$target_path'"
  local -- tmp_link
  tmp_link=$(mktemp -u "${target_dir}/.symlink-tmp-XXXXXX") || tmp_link=''
  if [[ -z "$tmp_link" ]]; then
    error "Failed to allocate temporary name in ${target_dir@Q}"
    ERROR_LINKS+=("$source_path → $target_path (link failed)")
    return 1
  fi
  if ! ln -s "$source_abs_path" "$tmp_link"; then
    error "Failed to create symlink ${target_path@Q}"
    ERROR_LINKS+=("$source_path → $target_path (link failed)")
    rm -f "$tmp_link" 2>/dev/null || :
    return 1
  fi
  if ! mv -fT "$tmp_link" "$target_path"; then
    error "Failed to install symlink ${target_path@Q}"
    ERROR_LINKS+=("$source_path → $target_path (link failed)")
    rm -f "$tmp_link" 2>/dev/null || :
    return 1
  fi

  ((was_replaced)) || CREATED_LINKS+=("$source_path → $target_path")
  success "Created symlink ${target_name@Q}"

  change_symlink_owner_perms "$source_abs_path" "$target_path"

  # Show details of the created symlink if verbose
  ((VERBOSE)) && { ls -lsd -- "$target_path" >&2 || :; }

  return 0
}

# change_symlink_owner_perms SOURCE_PATH SYMLINK_PATH
# Copies owner, group, and mtime from source to symlink (not file mode bits)
change_symlink_owner_perms() {
  local -- source_abs_path="$1" target_path="$2"
  # Get numeric owner/group — robust against missing /etc/passwd or
  # /etc/group entries on freshly-extracted archives (UNKNOWN would break
  # symbolic chown on hosts where a uid/gid has no name mapping yet).
  local -- uidgid
  uidgid=$(stat -c '%u:%g' "$source_abs_path" 2>/dev/null) || uidgid=''
  # Copy mtime from source to symlink
  debug "touch -h -r $source_abs_path $target_path"
  touch -h -r "$source_abs_path" "$target_path"
  # Change ownership of the symlink to match the source (numeric)
  debug "chown -h $uidgid $target_path"
  chown -h "$uidgid" "$target_path"
  return 0
}


# --------------------------------------------------------------------------------
# Cleanup operations
# --------------------------------------------------------------------------------
# delete_broken_symlinks DIRECTORY - Removes symlinks whose targets no longer exist
# Respects DRY_RUN flag; uses pure bash (no find) for safety
delete_broken_symlinks() {
  local -- target_dir="$1" link
  local -i count=0

  info "Finding broken symlinks in ${target_dir@Q}"

  if ((DRY_RUN)); then
    debug "Checking for broken symlinks in dry-run mode (safe approach)"

    # Use pure bash approach for safety
    for link in "$target_dir"/*; do
      # Skip if it's not a symlink
      [[ -L "$link" ]] || continue

      # Check if it's broken - target doesn't exist
      [[ ! -e "$link" ]] || continue

      # This is a broken symlink
      info "[DRY RUN] Would delete broken symlink ${link@Q}"
      count+=1
    done

    ((count==0)) || info "[DRY RUN] Would delete $count broken symlinks"
    return 0
  fi

  # REAL MODE: Actually delete broken symlinks
  debug "Finding and deleting broken symlinks (safe approach)"
  # The same pure bash approach - safer than using find
  for link in "$target_dir"/*; do
    # Skip if it's not a symlink
    [[ -L "$link" ]] || continue
    # Skip if the symlink target exists (i.e., not broken)
    [[ -e "$link" ]] && continue || :
    # This is a broken symlink - delete it
    info "Deleting broken symlink ${link@Q}"
    if rm "$link"; then
      count+=1
    else
      warn "Failed to delete broken symlink ${link@Q}"
    fi
  done

  ((count==0)) || success "Deleted $count broken symlinks"

  debug 'delete_broken_symlinks completed successfully'
  return 0
}

# --------------------------------------------------------------------------------
# .symlink file discovery
# --------------------------------------------------------------------------------
# find_symlink_files STARTPATH [MODE_NAME]
# Prints newline-separated paths of .symlink files at or below STARTPATH
# (depth ≤ FIND_MAX_DEPTH). MODE_NAME ("scanning"/"listing") only tunes the
# warning text. Returns non-zero when the underlying find fails (e.g. an
# unreadable subtree) so the caller can tell a real scan error from a genuinely
# empty result — output is empty in BOTH cases, the exit code is not.
find_symlink_files() {
  local -- startpath="${1%/}" mode_name="${2:-scanning}"
  # Scanning in/under the target dir is dangerous (it would re-link the links we
  # create), so restrict to the single direct .symlink file and warn.
  if [[ "$startpath" == "$DEFAULT_TARGET_DIR" \
        || "$startpath" == "$DEFAULT_TARGET_DIR"/* ]]; then
    warn "${mode_name^} in target directory ($DEFAULT_TARGET_DIR) is not recommended"
    [[ -f "$startpath/.symlink" ]] && printf '%s\n' "$startpath/.symlink" ||:
    return 0
  fi
  # pipefail (set at top) makes the pipeline inherit find's failure status, so a
  # permission-denied/IO error on the tree propagates instead of looking empty.
  find "$startpath" -maxdepth "$FIND_MAX_DEPTH" -type f -name '.symlink' | sort -u
}

# --------------------------------------------------------------------------------
# Summary and reporting
# --------------------------------------------------------------------------------
# print_summary - Outputs counts from global arrays; details if VERBOSE=1; errors always shown
print_summary() {
  # Format output differently for dry run mode
  if ((DRY_RUN)); then
    if (( ${#CREATED_LINKS[@]} == 0 && ${#REPLACED_LINKS[@]} ==0 &&
          ${#SKIPPED_LINKS[@]} ==0 && ${#ERROR_LINKS[@]} == 0 )); then
      echo "[DRY RUN] No operations would be performed."
      return 0
    fi
    echo '<DRY RUN>'
  else
    if (( ${#CREATED_LINKS[@]} == 0 && ${#REPLACED_LINKS[@]} == 0 &&
          ${#SKIPPED_LINKS[@]} == 0 && ${#ERROR_LINKS[@]} == 0 )); then
      ((VERBOSE)) && echo "No operations performed." ||:
      return 0
    fi
  fi

  # Calculate total processed
  local -i total
  total=$(( ${#CREATED_LINKS[@]} + ${#REPLACED_LINKS[@]}
    + ${#SKIPPED_LINKS[@]} + ${#ERROR_LINKS[@]} ))
  echo "Symlinks processed: $total"

  if(( ${#CREATED_LINKS[@]} )); then
    echo "Symlinks created: ${#CREATED_LINKS[@]}"
    if ((VERBOSE)); then
      local -- link
      for link in "${CREATED_LINKS[@]}"; do
        echo "  $link"
      done
    fi
  fi

  if (( ${#REPLACED_LINKS[@]} )); then
    echo "Symlinks replaced: ${#REPLACED_LINKS[@]}"
    if ((VERBOSE)); then
      local -- link
      for link in "${REPLACED_LINKS[@]}"; do
        echo "  $link"
      done
    fi
  fi

  if (( ${#SKIPPED_LINKS[@]} )); then
    echo "Skipped symlinks: ${#SKIPPED_LINKS[@]}"
    if ((VERBOSE)); then
      local -- link
      for link in "${SKIPPED_LINKS[@]}"; do
        echo "  $link"
      done
    fi
  fi

  # Always show errors regardless of verbosity
  if (( ${#ERROR_LINKS[@]} )); then
    echo "Errors: ${#ERROR_LINKS[@]}"
    local -- link
    for link in "${ERROR_LINKS[@]}"; do
      echo "  $link"
    done
  fi

  return 0
}

# --------------------------------------------------------------------------------
# Main function
# --------------------------------------------------------------------------------
# main ARGS... - Entry point: parses options, dispatches to scan/list/direct modes
main() {
  local -a targets=() # array of script paths to symlink
  local -- target_dir='' target=''
  local -i exit_code=0

  # Show usage if no arguments provided
  (($#)) || { >&2 show_help; return 1; }

  # Parse command line options
  while (($#)); do case $1 in
    # Feature options
    -t|--target-dir)    noarg "$@"; shift; target_dir=$1 ;;
    -l|--list)          LISTIT=1 ;;
    -P|--no-prompt)     PROMPT=0 ;;
    -S|--scan-symlink)  SCANSYMLINK=1 ;;
    -d|--delete-broken-symlinks)
                        DELETE_DEAD_SYMLINKS=1 ;;
    -f|--force)         FORCE=1 ;;
    --backup)           BACKUP=1 ;;
    # Basic options
    -h|--help)          show_help; return 0 ;;
    -v|--verbose)       VERBOSE=1 ;;
    -q|--quiet)         VERBOSE=0 ;;
    -V|--version)       echo "$SCRIPT_NAME $VERSION"; return 0 ;;
    -n|--dry-run)       DRY_RUN=1 ;;
    -D|--debug)         DEBUG=1 ;;

    # Handle combined short options (e.g., -vPd -> -v -P -d)
    -[tlPSdfhvqVnD]?*)  set -- "${1:0:2}" "-${1:2}" "${@:2}"; continue ;;
    # Error handling
    -*)                 die 22 "Invalid option ${1@Q}" ;;
    # Collect non-option arguments as target files/paths
    *)                  targets+=("$1") ;;
  esac; shift; done

  # Dry-run is a preview: surface per-file detail by default so -n shows which
  # links would be created/replaced/skipped (these route through info()).
  ((DRY_RUN)) && VERBOSE=1 ||:

  [[ -z $target_dir ]] && target_dir="$DEFAULT_TARGET_DIR"

  # Only check target dir if not in dry-run mode
  if ((DRY_RUN == 0)); then
    # Check if target directory exists and is writable
    [[ -d "$target_dir" ]] || die 3 "Target directory does not exist ${target_dir@Q}"

    [[ -w "$target_dir" ]] || die 2 "No write permission on target directory ${target_dir@Q}"
  fi

  # Process .symlink files if -l or -S options were used
  if ((LISTIT + SCANSYMLINK)); then
    # Allow only one startpath for listing or scanning operations
    local -- mode_name
    mode_name=$( ((LISTIT)) && echo "listing" || echo "scanning" )
    ((${#targets[@]} > 1)) && die 1 \
      "Can only specify one startpath for ${mode_name}."

    local -- startpath="$ORIG_DIR" symlink

    # Use the provided path if available, otherwise use current directory
    if ((${#targets[@]})); then
      # Handle relative paths correctly
      if [[ "${targets[0]}" != /* ]]; then
        startpath="$ORIG_DIR/${targets[0]}"
      else
        startpath="${targets[0]}"
      fi
      targets=()
    fi

    # Validate the startpath - use more robust path resolution
    info "Resolving path ${startpath@Q}"

    # Resolve startpath to absolute path
    startpath=$(
        realpath -- "$startpath" 2>/dev/null || echo ''
      )

    [[ -n "$startpath" ]] || die 1 "Failed to resolve path (invalid or inaccessible)"

    info "Resolved path ${startpath@Q}"
    [[ -d "$startpath" ]] || die 3 "Path is not a directory ${startpath@Q}"

    # Ensure the path exists and is accessible
    [[ -x "$startpath" ]] || die 2 "Path exists but is not accessible ${startpath@Q}"

    # Handle the -l (list) option - just show contents of .symlink files
    if ((LISTIT)); then
      info "Listing contents of all .symlink files"
      info "  starting in ${startpath@Q}"

      local -a symlink_files=()
      local -- symlink
      debug "Finding .symlink files"

      # Discover .symlink files. find_symlink_files surfaces a find failure as a
      # real error (die 1), distinct from a genuinely empty tree (die 50).
      local -- find_output=''
      find_output=$(find_symlink_files "$startpath" listing) \
        || die 1 "Error finding .symlink files for listing"
      [[ -n "$find_output" ]] && mapfile -t symlink_files <<< "$find_output" ||:
      (( ${#symlink_files[@]} )) || die 50 "No .symlink files found in ${startpath@Q}"

      debug "Found ${#symlink_files[@]} .symlink files for listing"

      local -- symlink_dir line
      for symlink in "${symlink_files[@]}"; do
        symlink_dir=$(dirname -- "$symlink")
        echo "$(basename -- "$symlink_dir")/.symlink (${symlink_dir}):"
        # Mirror the -S parser: strip inline comments, trim, skip blanks — so the
        # listing shows exactly the entries scanning would act on.
        while IFS= read -r line || [[ -n "$line" ]]; do
          line="${line%$'\r'}"
          line="${line%%#*}"
          line=$(trim "$line")
          [[ -z "$line" ]] && continue
          printf '    %s\n' "$line"
        done < "$symlink"
        echo
      done
      return 0
    fi

    # Handle the -S (scan) option - process .symlink files
    info "Scanning for all .symlink files starting in ${startpath@Q}"
    local -a symlinks=()
    local -- symlink

    # Safety first: Use controlled approach to avoid recursion issues
    startpath="${startpath%/}"  # Remove trailing slash if present
    debug "Start path for symlink scan ${startpath@Q}"

    if [[ ! -d "$startpath" ]] || [[ ! -r "$startpath" ]]; then
      die 3 "Cannot access directory ${startpath@Q}"
    fi

    # Discover .symlink files. find_symlink_files surfaces a find failure as a
    # real error (die 1), distinct from a genuinely empty tree (die 50).
    local -- find_output=''
    find_output=$(find_symlink_files "$startpath" scanning) \
      || die 1 "Error finding .symlink files"
    [[ -n "$find_output" ]] && mapfile -t symlinks <<< "$find_output" ||:
    (( ${#symlinks[@]} )) || die 50 "No .symlink files found in ${startpath@Q}"

    debug "Found ${#symlinks[@]} .symlink files to process"

    info "Found ${#symlinks[@]} .symlink files"

    # Process each .symlink file in batches
    ((${#symlinks[@]})) || die 50 'No .symlink files to process'

    local -i batch_size=5
    local -i processed=0
    local -i total=${#symlinks[@]}
    local -i batch_count=$(( (total + batch_size - 1) / batch_size ))

    info "Found and will process ${#symlinks[@]} .symlink files"
    debug "Processing in $batch_count batches"

    # Process in batches
    local -i start=0 end=0 i=0 count=0 batch=0
    local -- symlink symlink_dir line
    local -- script_path link_name source_file
    local -a link_names
    local -- source_raw remainder prev_char ch
    local -i idx=0 len=0 bad_name=0
    for ((batch=0; batch<batch_count; batch+=1)); do
      start=$((batch * batch_size))
      end=$(( (batch + 1) * batch_size ))
      (( end > total )) && end=$total

      info "Processing batch $((batch+1))/$batch_count"
      debug "Processing files $((start+1))-$end of $total"

      # Process each file in this batch
      for ((i=start; i<end; i+=1)); do
        symlink="${symlinks[$i]}"
        info "Processing: $symlink ($((i+1))/$total)"

        # Get the directory containing the .symlink file
        symlink_dir=$(dirname -- "$symlink")
        count=0

        # Read the .symlink file
        while IFS= read -r line || [[ -n "$line" ]]; do
          line="${line%$'\r'}"  # Strip Windows/Mac CR
          # Strip inline comments and trim whitespace
          line="${line%%#*}"
          line=$(trim "$line")
          [[ -z "$line" ]] && continue

          # Parse line into tokens: source [linkname...]
          # Supports backslash-escaped spaces in source paths (e.g., my\ script.sh)
          source_raw='' remainder=''
          idx=0 len=${#line}
          prev_char=''

          # Find first unescaped space to separate source from link names
          while ((idx < len)); do
            ch="${line:idx:1}"
            if [[ "$ch" == ' ' && "$prev_char" != $'\\' ]]; then
              source_raw="${line:0:idx}"
              remainder="${line:idx+1}"
              break
            fi
            prev_char="$ch"
            idx+=1
          done
          # No unescaped space found - entire line is source
          [[ -z "$source_raw" ]] && source_raw="$line"

          # Unescape backslash-spaces and build full path
          source_file="${source_raw//\\ / }"
          script_path="$symlink_dir/$source_file"

          # Build array of link names from remainder (default to basename if none)
          if [[ -n "$remainder" ]]; then
            remainder=$(trim "$remainder")
            if [[ -n "$remainder" ]]; then
              read -ra link_names <<< "$remainder"
            else
              link_names=("${source_file##*/}")
            fi
          else
            link_names=("${source_file##*/}")
          fi

          # Containment: .symlink content is trusted-but-verified. As root this
          # blocks a hostile tree from publishing PATH symlinks that escape the
          # .symlink directory (source) or the target directory (link name).
          # Reject sources that are absolute or contain a .. path component...
          if [[ "$source_file" == /* || "$source_file" == '..' \
                || "$source_file" == '../'* || "$source_file" == *'/../'* \
                || "$source_file" == *'/..' ]]; then
            error "Refusing source outside .symlink dir ${source_file@Q}"
            ERROR_LINKS+=("$script_path → $target_dir (source escapes tree)")
            continue
          fi
          # ...and reject link names that are not a single bare filename.
          bad_name=0
          for link_name in "${link_names[@]}"; do
            [[ "$link_name" == */* || "$link_name" == '.' || "$link_name" == '..' ]] || continue
            error "Refusing unsafe link name (must be a bare filename) ${link_name@Q}"
            ERROR_LINKS+=("$script_path → $target_dir/$link_name (unsafe link name)")
            bad_name=1
          done
          ((bad_name)) && continue ||:

          # Validate source file once before creating links
          if [[ ! -f "$script_path" ]]; then
            error "Source file does not exist: '$script_path'"
            for link_name in "${link_names[@]}"; do
              ERROR_LINKS+=("$script_path → $target_dir/$link_name (not found)")
            done
            continue
          fi

          if [[ ! -x "$script_path" ]]; then
            error "Source file not executable: '$script_path'"
            for link_name in "${link_names[@]}"; do
              ERROR_LINKS+=("$script_path → $target_dir/$link_name (not executable)")
            done
            continue
          fi

          # Create symlink for each link name (delegates to create_symlink)
          for link_name in "${link_names[@]}"; do
            create_symlink "$script_path" "$target_dir" "$link_name" || :
            count+=1
          done
        done < "$symlink"

        debug "Processed $count entries from $symlink"
        processed+=1
      done

      debug "Completed batch $((batch+1))/$batch_count"
    done

    info "Processed all $processed .symlink files"

  else
    # Process individual target files
    (( ${#targets[@]} )) || die 1 \
      "No target files specified. Use $SCRIPT_NAME --help for usage."

    info "Processing ${#targets[@]} individual target files"

    # Process each target file
    local -i processed=0
    for target in "${targets[@]}"; do
      [[ -n "$target" ]] || { warn "Empty target specified. Skipping."; continue; }
      info "Processing: $target ($((processed+1))/${#targets[@]})"
      create_symlink "$target" "$target_dir" || exit_code=$?
      processed+=1
    done
  fi

  # Optionally clean up broken symlinks
  ((DELETE_DEAD_SYMLINKS)) && delete_broken_symlinks "$target_dir"

  # Print summary of operations
  print_summary

  # Return appropriate exit code
  if (( ${#ERROR_LINKS[@]} )); then
    ((exit_code)) || exit_code=1
    warn "There were errors during processing (see messages above)."
  elif (( ${#CREATED_LINKS[@]} == 0 && ${#REPLACED_LINKS[@]} == 0 )); then
    if (( ${#SKIPPED_LINKS[@]} )); then
      warn 'No symlinks created. All operations were skipped.'
    else
      warn 'No symlinks processed. Make sure your paths are correct.'
    fi
  else
    success 'Operation completed successfully.'
  fi

  ((DRY_RUN)) && echo "Dry run completed. No changes were made." ||:
  debug "Exiting with code: $exit_code"
  return "$exit_code"
}

main "$@"
#fin
